#!/bin/bash
# ══════════════════════════════════════════════════════════════
# ai-setup — Define quais agents e serviços abrem por padrão no ai-dev
#
# Uso:
#   ai-setup              → wizard interativo
#   ai-setup --reset      → apaga config e roda wizard de novo
#
# Config salva em: ~/.config/ai-workspace/defaults.conf
# Formato:
#   DEFAULT_AGENTS="claude gemini aider" (espaço-separado)
#   DEFAULT_CLIPBOARD=true|false
#   DEFAULT_BROWSER=true|false
# ══════════════════════════════════════════════════════════════
set -e

CONFIG_DIR="$HOME/.config/ai-workspace"
CONFIG_FILE="$CONFIG_DIR/defaults.conf"

if [ "$1" = "--reset" ]; then
    rm -f "$CONFIG_FILE"
    echo "🗑️  Config removida."
fi

mkdir -p "$CONFIG_DIR"

ALL_AGENTS=(claude gemini qwen cursor opencode codex cline aider)

echo ""
echo "🔧 AI Workspace — Setup"
echo "══════════════════════════════════════"
echo ""
echo "Quais agents devem abrir por padrão no ai-dev?"
echo "(Quando rodar ai-dev <projeto> sem flags)"
echo ""

# Se já tem config, mostrar seleção atual
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
    echo "Config atual: $DEFAULT_AGENTS"
    echo ""
fi

# Mostrar opções com toggle
echo "Selecione os agents (espaço-separado, ex: 1 3 6):"
echo ""
for i in "${!ALL_AGENTS[@]}"; do
    printf "  %d) %s\n" $((i+1)) "${ALL_AGENTS[$i]}"
done
echo ""
echo "  a) Todos (${#ALL_AGENTS[@]} agents)"
echo ""
read -rp "Escolha: " CHOICES

if [ -z "$CHOICES" ]; then
    echo "❌ Nenhuma seleção feita."
    exit 1
fi

# Parsear seleção
SELECTED=()
if [[ "$CHOICES" =~ ^[aA]$ ]]; then
    SELECTED=("${ALL_AGENTS[@]}")
else
    for choice in $CHOICES; do
        idx=$((choice - 1))
        if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#ALL_AGENTS[@]}" ]; then
            SELECTED+=("${ALL_AGENTS[$idx]}")
        else
            echo "⚠️  '$choice' ignorado (fora do range)"
        fi
    done
fi

if [ ${#SELECTED[@]} -eq 0 ]; then
    echo "❌ Nenhum agent válido selecionado."
    exit 1
fi

# ── Serviços opcionais ──
echo ""
echo "══════════════════════════════════════"
echo ""
echo "Serviços opcionais:"
echo ""

# Clipboard
echo "  Clipboard bridge — cola imagens do PC via browser"
echo "  (servidor web em :3456, requer ai-tunnel)"
read -rp "  Ativar clipboard-server? [s/N]: " CLIP_CHOICE
case "$CLIP_CHOICE" in
    s|S|sim|y|Y|yes) DEFAULT_CLIPBOARD=true ;;
    *) DEFAULT_CLIPBOARD=false ;;
esac

echo ""

# Browser CDP
echo "  Chromium CDP — browser compartilhado com DevTools remoto"
echo "  (headless em :9222, dev e agents veem as mesmas abas)"
read -rp "  Ativar browser CDP? [s/N]: " BROWSER_CHOICE
case "$BROWSER_CHOICE" in
    s|S|sim|y|Y|yes) DEFAULT_BROWSER=true ;;
    *) DEFAULT_BROWSER=false ;;
esac

# Salvar
cat > "$CONFIG_FILE" << CONF
DEFAULT_AGENTS="${SELECTED[*]}"
DEFAULT_CLIPBOARD=$DEFAULT_CLIPBOARD
DEFAULT_BROWSER=$DEFAULT_BROWSER
CONF

echo ""
echo "✅ Defaults salvos:"
echo "   Agents:    ${SELECTED[*]}"
echo "   Clipboard: $DEFAULT_CLIPBOARD"
echo "   Browser:   $DEFAULT_BROWSER"
echo "   Config:    $CONFIG_FILE"
echo ""
echo "   ai-dev <projeto>              → abre defaults"
echo "   ai-dev <projeto> --claude     → override: só claude"
echo "   ai-dev <projeto> --all        → override: todos os 8"
echo "   ai-dev <projeto> --clipboard  → override: ativa clipboard"
echo "   ai-dev <projeto> --browser    → override: ativa browser"
echo ""
if $DEFAULT_CLIPBOARD || $DEFAULT_BROWSER; then
    PORTS=""
    $DEFAULT_CLIPBOARD && PORTS="3456"
    $DEFAULT_BROWSER && PORTS="${PORTS:+$PORTS }9222"
    echo "   Lembre de rodar no host: ai-tunnel $PORTS"
    echo ""
fi
