#!/bin/bash
# ══════════════════════════════════════════════════════════════
# ai-dev — Cria/reconecta workspace tmux por projeto
#
# Uso:
#   ai-dev <projeto>                     → padrão: TODOS os agents (= --all)
#   ai-dev <projeto> --claude            → só Claude
#   ai-dev <projeto> --claude --gemini   → Claude + Gemini
#   ai-dev <projeto> --qwen --cursor     → Qwen + Cursor
#   ai-dev <projeto> --codex --aider     → Codex + Aider
#   ai-dev <projeto> --rc                → adiciona Remote Control no Claude
#   ai-dev <projeto> --danger            → skip-permissions/yolo nos agents que suportam
#   ai-dev <projeto> --clipboard         → inicia clipboard bridge (cola imagens via browser)
#   ai-dev <projeto> --browser           → inicia Chromium headless com CDP (DevTools remoto)
#
# Regras:
#   • Sem nenhuma flag de agent → abre os DEFAULTS (configurados via ai-setup)
#   • Com qualquer flag de agent → abre SOMENTE os nomeados
#   • --all abre TODOS os 8 agents (override dos defaults)
#   • --rc, --danger, --clipboard, --browser são flags modificadoras (não contam como "agent flag")
#
# Flags de prompt one-shot (referência — usadas pelo ralph, não pelo ai-dev):
#   claude   -p "prompt"                  (--print)
#   gemini   -p "prompt"                  (--prompt)
#   qwen     -p "prompt"                  (--prompt)
#   cursor   -p "prompt"                  (cursor-agent --print)
#   opencode run "prompt"                 (subcomando, não flag)
#   codex    -q "prompt"                  (--quiet, one-shot)
#   cline    -y -m "prompt"              (headless + message)
#   aider    -m "prompt" --yes-always     (message + auto-approve)
#
# Flags de "danger" por CLI:
#   claude   --dangerously-skip-permissions
#   gemini   --yolo
#   qwen     --yolo
#   cursor   -f                           (--force)
#   opencode (sem equivalente — ignora --danger)
#   codex    --yolo
#   cline    --yolo
#   aider    --yes-always
# ══════════════════════════════════════════════════════════════
set -e

PROJECT="${1:?Uso: ai-dev <projeto> [--claude] [--gemini] [--qwen] [--cursor] [--opencode] [--codex] [--cline] [--aider] [--all] [--rc] [--danger] [--clipboard] [--browser]}"
shift

# ── Parsear flags ──
RC=false
DANGER=false
CLIPBOARD=false
BROWSER=false
CLAUDE=false
GEMINI=false
QWEN=false
CURSOR=false
OPENCODE=false
CODEX=false
CLINE=false
AIDER=false
ANY_AGENT=false

for flag in "$@"; do
    case "$flag" in
        --rc)        RC=true ;;
        --danger)    DANGER=true ;;
        --clipboard) CLIPBOARD=true ;;
        --browser)   BROWSER=true ;;
        --claude)   CLAUDE=true;   ANY_AGENT=true ;;
        --gemini)   GEMINI=true;   ANY_AGENT=true ;;
        --qwen)     QWEN=true;     ANY_AGENT=true ;;
        --cursor)   CURSOR=true;   ANY_AGENT=true ;;
        --opencode) OPENCODE=true; ANY_AGENT=true ;;
        --codex)    CODEX=true;    ANY_AGENT=true ;;
        --cline)    CLINE=true;    ANY_AGENT=true ;;
        --aider)    AIDER=true;    ANY_AGENT=true ;;
        --all)      # força TODOS os agents (ignora defaults)
                    CLAUDE=true; GEMINI=true; QWEN=true; CURSOR=true
                    OPENCODE=true; CODEX=true; CLINE=true; AIDER=true
                    ANY_AGENT=true ;;  # marca true pra pular bloco de defaults
    esac
done

# ── Carregar config (agents, clipboard, browser) ──
CONFIG_FILE="$HOME/.config/ai-workspace/defaults.conf"

_load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
        for agent in $DEFAULT_AGENTS; do
            case "$agent" in
                claude)   CLAUDE=true ;;
                gemini)   GEMINI=true ;;
                qwen)     QWEN=true ;;
                cursor)   CURSOR=true ;;
                opencode) OPENCODE=true ;;
                codex)    CODEX=true ;;
                cline)    CLINE=true ;;
                aider)    AIDER=true ;;
            esac
        done
        # Serviços: só aplica default se flag não foi passada explicitamente
        $CLIPBOARD || CLIPBOARD="${DEFAULT_CLIPBOARD:-false}"
        $BROWSER   || BROWSER="${DEFAULT_BROWSER:-false}"
        return 0
    fi
    return 1
}

if ! $ANY_AGENT; then
    if ! _load_config; then
        # Primeiro uso: rodar wizard
        echo "⚙️  Primeira execução — configurando defaults..."
        echo ""
        ai-setup
        if ! _load_config; then
            # Fallback se wizard cancelou: abre todos
            CLAUDE=true; GEMINI=true; QWEN=true; CURSOR=true
            OPENCODE=true; CODEX=true; CLINE=true; AIDER=true
        fi
    fi
else
    # Agent flags explícitas, mas ainda carregar defaults de serviços
    _load_config 2>/dev/null || true
fi

DIR="$HOME/projects/$PROJECT"
mkdir -p "$DIR"

# ── Sincronizar agent links (skills, instruction files, symlinks) ──
# Roda a cada attach — garante que skills globais novas apareçam
SETUP_SCRIPT="$(dirname "$0")/setup-agent-links"
if [ -x "$SETUP_SCRIPT" ]; then
    "$SETUP_SCRIPT" "$DIR" 2>/dev/null || true
fi

# ── Reconectar se já existe ──
if tmux has-session -t "$PROJECT" 2>/dev/null; then
    echo "♻️  Reconectando na sessão '$PROJECT'..."
    tmux attach -t "$PROJECT"
    exit 0
fi

echo "🚀 Criando workspace '$PROJECT'..."

# ── Montar comandos (cada CLI tem seu próprio danger flag) ──
CLAUDE_CMD="claude"
$RC     && CLAUDE_CMD="$CLAUDE_CMD --remote-control"
$DANGER && CLAUDE_CMD="$CLAUDE_CMD --dangerously-skip-permissions"

GEMINI_CMD="gemini --resume"
$DANGER && GEMINI_CMD="$GEMINI_CMD --yolo"

QWEN_CMD="qwen"
$DANGER && QWEN_CMD="$QWEN_CMD --yolo"

CURSOR_CMD="cursor"
$DANGER && CURSOR_CMD="$CURSOR_CMD -f"

# opencode não tem equivalente a yolo/skip-permissions
OPENCODE_CMD="opencode"

CODEX_CMD="codex"
$DANGER && CODEX_CMD="$CODEX_CMD --yolo"

CLINE_CMD="cline"
$DANGER && CLINE_CMD="$CLINE_CMD --yolo"

AIDER_CMD="aider"
$DANGER && AIDER_CMD="$AIDER_CMD --yes-always"

# ── Criar sessão (window inicial é a primeira CLI ativa) ──
FIRST_WINDOW_CREATED=false

open_window() {
    local name="$1"
    local cmd="$2"
    if ! $FIRST_WINDOW_CREATED; then
        tmux new-session -d -s "$PROJECT" -n "$name" -c "$DIR"
        FIRST_WINDOW_CREATED=true
    else
        tmux new-window -t "$PROJECT" -n "$name" -c "$DIR"
    fi
    tmux send-keys -t "$PROJECT" "$cmd" C-m
}

$CLAUDE   && open_window "claude"   "$CLAUDE_CMD"
$GEMINI   && open_window "gemini"   "$GEMINI_CMD"
$QWEN     && open_window "qwen"     "$QWEN_CMD"
$CURSOR   && open_window "cursor"   "$CURSOR_CMD"
$OPENCODE && open_window "opencode" "$OPENCODE_CMD"
$CODEX   && open_window "codex"    "$CODEX_CMD"
$CLINE   && open_window "cline"    "$CLINE_CMD"
$AIDER   && open_window "aider"    "$AIDER_CMD"

# ── Shell livre (sempre) ──
if ! $FIRST_WINDOW_CREATED; then
    tmux new-session -d -s "$PROJECT" -n "shell" -c "$DIR"
else
    tmux new-window -t "$PROJECT" -n "shell" -c "$DIR"
fi

# ── Focar na primeira window ──
tmux select-window -t "$PROJECT":1

# ── Serviços opcionais (clipboard + browser) ──
TUNNEL_PORTS=""

if $CLIPBOARD; then
    CLIP_PORT=3456
    if ! ss -tlnp 2>/dev/null | grep -q ":$CLIP_PORT "; then
        node "$HOME/bin/ai-clipboard" "$CLIP_PORT" &
        disown
        sleep 1
    fi
    TUNNEL_PORTS="$CLIP_PORT"
fi

if $BROWSER; then
    CDP_PORT=9222
    "$HOME/bin/ai-browser" "$CDP_PORT"
    TUNNEL_PORTS="${TUNNEL_PORTS:+$TUNNEL_PORTS }$CDP_PORT"
fi

# ── Info ──
AGENTS=""
$CLAUDE   && AGENTS="${AGENTS}${AGENTS:+ + }claude"
$GEMINI   && AGENTS="${AGENTS}${AGENTS:+ + }gemini"
$QWEN     && AGENTS="${AGENTS}${AGENTS:+ + }qwen"
$CURSOR   && AGENTS="${AGENTS}${AGENTS:+ + }cursor"
$OPENCODE && AGENTS="${AGENTS}${AGENTS:+ + }opencode"
$CODEX   && AGENTS="${AGENTS}${AGENTS:+ + }codex"
$CLINE   && AGENTS="${AGENTS}${AGENTS:+ + }cline"
$AIDER   && AGENTS="${AGENTS}${AGENTS:+ + }aider"
echo "   Agents: ${AGENTS:-shell only}"
$DANGER && echo "   Modo DANGER ativo"
$CLIPBOARD && echo "   Clipboard bridge ativo (:$CLIP_PORT)"
$BROWSER && echo "   Chromium CDP ativo (:$CDP_PORT)"

if [ -n "$TUNNEL_PORTS" ]; then
    echo ""
    echo "   Para acessar do PC, rode no host da VPS:"
    echo "     ai-tunnel $TUNNEL_PORTS"
    echo ""
    $CLIPBOARD && echo "   Browser: http://localhost:$CLIP_PORT (clipboard)"
    $BROWSER   && echo "   Chrome:  chrome://inspect → localhost:$CDP_PORT (DevTools)"
    echo ""
fi

# ── Attach ──
tmux attach -t "$PROJECT"
